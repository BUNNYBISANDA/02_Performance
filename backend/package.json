{
  "name": "o2-quality-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "import:excel": "tsx src/scripts/safeRefreshFromExcel.ts",
    "refresh:data": "tsx src/scripts/safeRefreshFromExcel.ts",
    "refresh:data:and-export": "tsx src/scripts/safeRefreshFromExcel.ts --export-static",
    "refresh:views": "tsx src/db/refreshMaterializedViews.ts",
    "export:static": "tsx src/scripts/exportStaticData.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
