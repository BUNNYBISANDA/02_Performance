DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/O2_Performance
# Set to true when DATABASE_URL points at a managed/hosted Postgres instance that requires SSL.
DATABASE_SSL=false
PORT=4000
EXCEL_FILE_PATH=backend/data/7QA_All_Customer_v2.xlsx
# Safe refresh validation guardrails.
EXPECTED_DATA_START_DATE=2026-01-01
EXPECTED_DATA_END_DATE=2026-06-30
DATA_REFRESH_WARNING_PERCENT=50
# Comma-separated list of allowed browser origins, in addition to any localhost/127.0.0.1 port.
CORS_ORIGINS=https://bunnybisanda.github.io
