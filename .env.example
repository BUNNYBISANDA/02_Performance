# Copy this file to .env.development / .env.production (or .env.local) and adjust as needed.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Base URL of the backend API, including the /api suffix.
# Local backend: http://localhost:4000/api
# Deployed backend: https://YOUR_DEPLOYED_BACKEND_URL/api
VITE_API_BASE_URL=http://localhost:4000/api

# "api"    = call VITE_API_BASE_URL (needs a deployed/running backend).
# "static" = read pre-exported JSON from VITE_STATIC_DATA_BASE_URL instead (no backend
#            needed — used on GitHub Pages). Run `cd backend && npm run export:static`
#            to generate that JSON.
VITE_DATA_MODE=api

# Only read when VITE_DATA_MODE=static. Should match this app's deployed base path
# (the `base` option in vite.config.ts) with /data appended. If unset, it falls back to
# `${import.meta.env.BASE_URL}data`, which always matches the real configured base.
VITE_STATIC_DATA_BASE_URL=/data

# This app has no mock data implementation. Keep this false; it exists only so a
# deployment can explicitly assert mock mode is off instead of silently using real data.
VITE_USE_MOCK_DATA=false
